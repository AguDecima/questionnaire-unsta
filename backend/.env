PORT=4000
API_CLIENT_KEY=unsta-super-secret-key
GSHEET_ID=1CvZ5js4sBiuFXmO_cUPOdSMUUPxTWuOvW_j9JqJdz80

# Pestaña y rango para agregar filas (debe alcanzar todas las columnas: meta + una por pregunta).
GSHEET_TAB=Respuestas
GSHEET_APPEND_RANGE=Respuestas!A:ZZ

# Lectura de DNI existentes (columna A desde fila 2; fila 1 = encabezados).
GSHEET_DNI_READ_RANGE=Respuestas!A2:A5000

# Opción 1 — archivo JSON de cuenta de servicio (recomendado en local):
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/credentials.json